# App
APP_NAME=Rent-A-Equip
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database — must match root .env credentials
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rentaequip

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# CORS — frontend URL
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Support email shown to users for disputes
SUPPORT_EMAIL=support@rentaequip.com